// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
{
  "agent": { "button": false, "default_width": 500, "default_profile": "ask", "dock": "right" },
  "auto_indent_on_paste": true,
  "base_keymap": "VSCode",
  "buffer_font_features": { "calt": true },
  "buffer_font_size": 15,
  "code_actions_on_format": { "source.fixAll": true, "source.organizeImports": true },
  "collaboration_panel": { "button": false },
  "cursor_blink": false,
  "cursor_shape": "block",
  "dap": {
    "netcoredbg": {
      "binary": "C:\\Users\\jgcaceres97\\.netcoredbg\\netcoredbg\\netcoredbg.exe",
      "args": ["--interpreter=vscode"]
    }
  },
  "debugger": { "format_dap_log_messages": true, "log_dap_communications": true },
  "diagnostics": { "inline": { "enabled": true } },
  "diff_view_style": "unified",
  "edit_predictions": { "mode": "eager" },
  "ensure_final_newline_on_save": true,
  "file_scan_exclusions": ["**/.git", "**/.next", "**/vendor", "**/coverage", "**/tmp"],
  "file_types": {
    "Ansible": ["**.ansible.yml", "**.ansible.yaml", "**playbook*.yaml", "**playbook*.yml"]
  },
  "git_panel": {
    "default_width": 280,
    "dock": "right",
    "show_count_badge": true,
    "sort_by_path": true,
    "tree_view": true
  },
  "icon_theme": "Soft Charmed Icons",
  "inlay_hints": {
    "enabled": false,
    "show_background": false,
    "show_type_hints": false,
    "toggle_on_modifiers_press": { "alt": true }
  },
  "languages": {
    "JavaScript": {
      "code_actions_on_format": { "source.fixAll": true, "source.organizeImports": true },
      "formatter": "prettier"
    },
    "JSON": { "formatter": "prettier" },
    "JSONC": { "formatter": "prettier" },
    "TSX": {
      "formatter": "prettier",
      "language_servers": ["eslint", "typescript-language-server"]
    },
    "TypeScript": {
      "code_actions_on_format": { "source.fixAll": true, "source.organizeImports": true },
      "formatter": "prettier",
      "language_servers": ["eslint", "typescript-language-server"]
    }
  },
  "linked_edits": true,
  "lsp": {
    "yaml-language-server": {
      "settings": {
        "yaml": {
          "schemas": {
            "https://raw.githubusercontent.com/ansible/ansible-lint/main/src/ansiblelint/schemas/inventory.json": [
              "./inventory/*.yaml",
              "hosts.yml"
            ]
          }
        }
      }
    }
  },
  "minimap": { "show": "always", "thumb": "always" },
  "outline_panel": { "dock": "right" },
  "preferred_line_length": 100,
  "prettier": {
    "arrowParens": "avoid",
    "bracketSameLine": false,
    "bracketSpacing": true,
    "endOfLine": "lf",
    "jsxSingleQuote": false,
    "objectWrap": "collapse",
    "printWidth": 100,
    "proseWrap": "preserve",
    "quoteProps": "as-needed",
    "semi": true,
    "singleAttributePerLine": true,
    "singleQuote": false,
    "tabWidth": 2,
    "trailingComma": "none",
    "useTabs": false
  },
  "project_panel": {
    "auto_fold_dirs": true,
    "auto_reveal_entries": true,
    "default_width": 280,
    "dock": "right"
  },
  "remove_trailing_whitespace_on_save": true,
  "restore_on_startup": "launchpad",
  "selection_highlight": false,
  "soft_wrap": "none",
  "tab_bar": { "show_nav_history_buttons": false },
  "tab_size": 2,
  "tabs": { "file_icons": true, "git_status": true, "show_diagnostics": "all" },
  "telemetry": { "diagnostics": false, "metrics": false },
  "terminal": {
    "default_height": 280,
    "font_family": "FiraCode Nerd Font Mono",
    "font_size": 14,
    "shell": { "program": "C:\\Program Files\\Git\\bin\\bash.exe" },
    "toolbar": { "breadcrumbs": false }
  },
  "theme": { "dark": "One Dark Pro", "light": "One Light", "mode": "dark" },
  "title_bar": { "show_branch_status_icon": true, "show_sign_in": false },
  "toolbar": { "breadcrumbs": true },
  "ui_font_size": 16,
  "use_on_type_format": true,
  "wrap_guides": [100]
}
